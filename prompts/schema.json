{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "symbol": { "type": "string" },
    "timeframe": { "type": "string" },
    "mode": { "type": "string" },
    "macro_bias": { "type": "string" },
    "technical_bias": { "type": "string" },
    "liquidity_state": { "type": "string" },
    "setup_type": { "type": "string" },
    "confidence": { "type": "number" },
    "risk_score": { "type": "number" },
    "data_quality": { "type": "number" },
    "action_class": { "type": "string", "enum": ["trade_candidate", "watchlist", "no_trade", "reassess"] },
    "execution_allowed": { "type": "boolean" },
    "journal_required": { "type": "boolean" },
    "failed_gate": { "type": ["string", "null"] },
    "entry_plan": {
      "type": "object",
      "properties": {
        "entry": { "type": "string" },
        "stop": { "type": "string" },
        "targets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "conflict_flags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "required": [
    "symbol", "timeframe", "mode", "macro_bias", "technical_bias", 
    "liquidity_state", "setup_type", "confidence", "risk_score", 
    "data_quality", "action_class", "execution_allowed", "journal_required", 
    "entry_plan", "conflict_flags", "notes"
  ]
}
